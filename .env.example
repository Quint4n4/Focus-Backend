# ─────────────────────────────────────────────────────────────────
# Focus Backend — Variables de entorno
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env al control de versiones.
# ─────────────────────────────────────────────────────────────────

# ── Django ──
SECRET_KEY=django-insecure-cambia-este-valor-en-produccion
JWT_SECRET_KEY=otro-secreto-diferente-al-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ──
DATABASE_URL=postgres://postgres:password@localhost:5432/focus
# Para Docker Compose, usar el nombre del servicio:
# DATABASE_URL=postgres://postgres:password@db:5432/focus
DB_NAME=focus
DB_USER=postgres
DB_PASSWORD=password

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
# Para Docker Compose:
# REDIS_URL=redis://redis:6379/0

# ── CORS — orígenes permitidos separados por coma ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Sentry (solo producción — dejar vacío en desarrollo) ──
SENTRY_DSN=

# ── Configuración del módulo de settings ──
# Desarrollo: config.settings.local
# Producción: config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.local
